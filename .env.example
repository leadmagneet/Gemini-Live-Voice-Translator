GEMINI_API_KEY=

REAL_MIC_ID=
CABLE_INPUT_ID=
VOICEMEETER_OUT_ID=
REAL_PHONES_ID=

OUTGOING_TARGET_LANG=en
OUTGOING_PIPELINE_NAME=OUTGOING_TO_EN

INCOMING_TARGET_LANG=ru
INCOMING_PIPELINE_NAME=INCOMING_TO_RU

MODEL_NAME=gemini-3.5-live-translate-preview
ENABLE_TRANSCRIPTS=1
REALTIME_INPUT_CONFIG=0

# Record the call: 1 = save logs/<date>/original.wav + translated.wav + transcript.log, 0 = off
RECORD_SESSION=0

CAPTURE_FRAMES=480
PLAYBACK_FRAMES=480
GEMINI_CHUNK_MS=100

MAX_CAPTURE_QUEUE_MS=700
MAX_PLAYBACK_QUEUE_MS=600
MAX_WS_BUFFERED_BYTES=262144
RECONNECT_DELAY_MS=3000
